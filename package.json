{
    "name": "playwright-orchestrator",
    "version": "1.2.1",
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "watch": "tsc -b -w",
        "test": "vitest run --pool threads",
        "build": "tsc -b --clean && tsc -b --sourceMap false",
        "test-update": "vitest -u",
        "start": "node --inspect packages/core/dist/cli",
        "dynamo-local": "podman compose -f ./packages/dynamo-db/compose.yml",
        "pg-local": "podman compose -f ./packages/pg/compose.yml",
        "mysql-local": "podman compose -f ./packages/mysql/compose.yml",
        "mongo-local": "podman compose -f ./packages/mongo/compose.yml",
        "redis-local": "podman compose -f ./packages/redis/compose.yml",
        "version:patch": "pnpm -r exec -- npm version patch --no-git-tag-version && npm version patch --git-tag-version false",
        "version:minor": "pnpm -r exec -- npm version minor --no-git-tag-version && npm version minor --git-tag-version false",
        "version:major": "pnpm -r exec -- npm version major --no-git-tag-version && npm version major --git-tag-version false"
    },
    "private": true,
    "keywords": [],
    "author": "Rostyslav Kudrevatykh",
    "license": "Apache-2.0",
    "description": "",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rostmanrk/playwright-orchestrator.git"
    },
    "devDependencies": {
        "@playwright-orchestrator/core": "workspace:*",
        "@playwright-orchestrator/dynamo-db": "workspace:*",
        "@playwright-orchestrator/file": "workspace:*",
        "@playwright-orchestrator/mongo": "workspace:*",
        "@playwright-orchestrator/mysql": "workspace:*",
        "@playwright-orchestrator/pg": "workspace:*",
        "@playwright-orchestrator/redis": "workspace:*",
        "@playwright/test": "^1.49.1",
        "@types/node": "^22.10.2",
        "playwright": "^1.49.1",
        "typescript": "^5.7.3",
        "prettier": "3.4.2",
        "vitest": "^3.0.5"
    }
}
