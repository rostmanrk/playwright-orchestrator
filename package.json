{
    "name": "playwright-orchestrator",
    "version": "1.3.3",
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "watch": "tsc -b -w",
        "test": "vitest run --pool=threads",
        "test:unit": "vitest run --pool=threads --exclude=**/e2e/**",
        "test:e2e": "npx http-server ./e2e/web-server-simulation -p 4321 --silent & SERVER_PID=$!; trap 'kill $SERVER_PID' EXIT && vitest run **/e2e/** --pool=threads --poolOptions.threads.maxThreads=2",
        "test:ci": "npx http-server ./e2e/web-server-simulation -p 4321 --silent & SERVER_PID=$!; trap 'kill $SERVER_PID' EXIT && vitest run --pool=threads --poolOptions.threads.maxThreads=1",
        "build": "tsc -b --clean && tsc -b --sourceMap false",
        "test-update": "vitest -u",
        "start": "node --inspect packages/core/dist/cli",
        "dynamo-local": "podman compose -f ./packages/dynamo-db/compose.yml",
        "pg-local": "podman compose -f ./packages/pg/compose.yml",
        "mysql-local": "podman compose -f ./packages/mysql/compose.yml",
        "mongo-local": "podman compose -f ./packages/mongo/compose.yml",
        "redis-local": "podman compose -f ./packages/redis/compose.yml",
        "version:patch": "pnpm -r --include-workspace-root exec -- pnpm version patch --no-git-tag-version",
        "version:minor": "pnpm -r --include-workspace-root exec -- pnpm version minor --no-git-tag-version",
        "version:major": "pnpm -r --include-workspace-root exec -- pnpm version major --no-git-tag-version"
    },
    "private": true,
    "keywords": [],
    "author": "Rostyslav Kudrevatykh",
    "license": "Apache-2.0",
    "description": "",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rostmanrk/playwright-orchestrator.git"
    },
    "pnpm": {
        "overrides": {
            "@playwright-orchestrator/core": "workspace:*",
            "@playwright-orchestrator/dynamo-db": "workspace:*",
            "@playwright-orchestrator/file": "workspace:*",
            "@playwright-orchestrator/mongo": "workspace:*",
            "@playwright-orchestrator/mysql": "workspace:*",
            "@playwright-orchestrator/pg": "workspace:*",
            "@playwright-orchestrator/redis": "workspace:*"
        }
    },
    "devDependencies": {
        "@playwright-orchestrator/core": "workspace:*",
        "@playwright-orchestrator/dynamo-db": "workspace:*",
        "@playwright-orchestrator/file": "workspace:*",
        "@playwright-orchestrator/mongo": "workspace:*",
        "@playwright-orchestrator/mysql": "workspace:*",
        "@playwright-orchestrator/pg": "workspace:*",
        "@playwright-orchestrator/redis": "workspace:*",
        "@playwright/test": "^1.49.1",
        "@types/node": "^22.10.2",
        "esbuild": "^0.27.4",
        "playwright": "^1.49.1",
        "prettier": "3.4.2",
        "typescript": "^5.7.3",
        "vitest": "^3.0.5"
    }
}
